{
  "version": 2,
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" },
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/frontend/index.html" },
    { "src": "/news", "dest": "/frontend/news.html" },
    { "src": "/login", "dest": "/frontend/login.html" },
    { "src": "/quiz", "dest": "/frontend/quiz.html" },
    { "src": "/profile", "dest": "/frontend/profile.html" },
    { "src": "/admin", "dest": "/frontend/admin.html" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
